# Copy to .env (gitignored) and adjust as needed: cp .env.example .env

# --- PostgreSQL ---
POSTGRES_USER=app              # database user
POSTGRES_PASSWORD=app          # database password
POSTGRES_DB=app                # database name
POSTGRES_PORT=5432             # host port mapped to Postgres

# --- Backend (go-github-tracker-ms) ---
BACKEND_PORT=12010             # host port mapped to the API

# --- Frontend (Next.js) ---
FRONTEND_PORT=3000             # host port mapped to the web app
