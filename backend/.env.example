# Backend config for local (non-Docker) runs.
# Copy to .env (gitignored) and adjust: cp .env.example .env
# Real exported env vars always take precedence over this file.

# PostgreSQL DSN (required)
GOGITHUBTRACKER_DB_DSN=postgres://app:app@localhost:5432/app?sslmode=disable

# Bind address (optional, default :12010 — all interfaces on that port)
GOGITHUBTRACKER_LISTEN=:12010

# GitHub API token (optional). When set, raises the API rate limit; the public
# API works without it for low-volume use.
# GITHUB_TOKEN=ghp_xxx
